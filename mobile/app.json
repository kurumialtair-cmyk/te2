{
  "expo": {
    "name": "Privies",
    "slug": "thrift-price-estimator",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#12061F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Used to capture full item and brand label photos for price estimation.",
        "NSPhotoLibraryUsageDescription": "Used to select photos for price estimation."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#12061F"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE"
      ],
      "package": "com.aikssan.thriftpriceestimator"
    },
    "extra": {
      "eas": {
        "projectId": "14356357-cb3f-464d-83dd-d092acd24a36"
      }
    }
  }
}
